COMPOSE_PROJECT_NAME=aplis

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=aplis
MYSQL_USER=aplis
MYSQL_PASSWORD=aplispass

# API ports (container internal)
BACKEND_NODE_PORT=3000
BACKEND_PHP_PORT=80

# Host ports (exposed)
HOST_MYSQL_PORT=3306
HOST_BACKEND_NODE_PORT=3001
HOST_BACKEND_PHP_PORT=3002
HOST_FRONTEND_PORT=8080
